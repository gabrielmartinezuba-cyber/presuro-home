---
<header class="fixed top-0 left-0 right-0 z-50 bg-white/70 backdrop-blur-xl border-b border-white/20 shadow-sm transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between py-4 min-h-[5rem]">
      <div class="flex-shrink-0 flex items-center gap-2">
        <a href="/" class="flex items-center group">
          <img 
            src="/logo.png" 
            alt="PresuroHome Logo" 
            class="w-40 md:w-48 h-auto object-contain drop-shadow-sm group-hover:opacity-90 transition-opacity" 
          />
        </a>
      </div>
      <nav class="hidden md:flex gap-8">
        <a href="#estudios" class="text-sm font-medium text-slate-600 hover:text-brand-red transition-colors">Estudios</a>
        <a href="#como-funciona" class="text-sm font-medium text-slate-600 hover:text-brand-red transition-colors">Cómo Funciona</a>
        <a href="#faq" class="text-sm font-medium text-slate-600 hover:text-brand-red transition-colors">Preguntas Frecuentes</a>
      </nav>
      <div class="flex items-center">
        <!-- CTA header -->
        <a href="#contacto" class="hidden md:inline-flex items-center justify-center px-6 py-2.5 text-sm font-medium text-brand-red bg-brand-red/10 rounded-full hover:bg-brand-red hover:text-white transition-all duration-300">
          Pedir Turno
        </a>
      </div>
    </div>
  </div>
</header>
