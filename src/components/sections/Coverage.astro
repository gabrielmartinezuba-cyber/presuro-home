---
const GBA_ZONES = [
    "Ciudadela",
    "Ramos Mejía",
    "Haedo",
    "Morón",
    "Castelar",
    "Ituzaingó",
    "Palermo Oeste",
    "El Palomar",
];

const CABA_ZONES = [
    "Caballito",
    "Flores",
    "Floresta",
    "Vélez Sársfield",
    "Monte Castro",
    "Liniers",
    "Mataderos",
    "Villa Luro",
];
---

<section id="cobertura" class="py-24 sm:py-32 bg-white relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center max-w-3xl mx-auto mb-16 px-4">
            <h2 class="text-sm font-semibold tracking-wide text-brand-red uppercase mb-3">Zonas de Cobertura</h2>
            <h3 class="text-4xl md:text-5xl font-display font-bold text-slate-900 tracking-tight lg:leading-tight mb-6">
                ¿Llegamos a tu zona?
            </h3>
            <p class="text-lg text-slate-600 font-body">
                Llevamos nuestra tecnología de diagnóstico directamente a tu domicilio. Revisá nuestras áreas de atención prioritarias.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-stretch">
            {/* Card 1: GBA Oeste */}
            <div class="p-8 rounded-[2rem] bg-white border border-slate-100 shadow-premium flex flex-col md:hover:shadow-2xl md:hover:border-slate-300 transition-all duration-300 group active:scale-[0.98] active:bg-slate-50 cursor-default">
                <div class="flex items-center gap-4 mb-8">
                    <div class="w-14 h-14 rounded-2xl bg-slate-50 flex items-center justify-center text-brand-red md:group-hover:scale-110 transition-transform duration-300">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                    </div>
                    <h4 class="text-2xl font-display font-bold text-slate-900 tracking-tight">GBA Oeste</h4>
                </div>
                
                <ul class="space-y-4 flex-grow">
                    {GBA_ZONES.map(zona => (
                        <li class="flex items-start gap-3 text-slate-600">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-brand-red/80 shrink-0 mt-0.5"><path d="M20 6 9 17l-5-5"/></svg>
                            <span class="font-medium text-[15px]">{zona}</span>
                        </li>
                    ))}
                </ul>
            </div>

            {/* Card 2: CABA */}
            <div class="p-8 rounded-[2rem] bg-white border border-slate-100 shadow-premium flex flex-col md:hover:shadow-2xl md:hover:border-slate-300 transition-all duration-300 group active:scale-[0.98] active:bg-slate-50 cursor-default">
                <div class="flex items-center gap-4 mb-8">
                    <div class="w-14 h-14 rounded-2xl bg-slate-50 flex items-center justify-center text-brand-red md:group-hover:scale-110 transition-transform duration-300">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                    </div>
                    <h4 class="text-2xl font-display font-bold text-slate-900 tracking-tight">CABA</h4>
                </div>
                
                <ul class="space-y-4 flex-grow">
                    {CABA_ZONES.map(zona => (
                        <li class="flex items-start gap-3 text-slate-600">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-brand-red/80 shrink-0 mt-0.5"><path d="M20 6 9 17l-5-5"/></svg>
                            <span class="font-medium text-[15px]">{zona}</span>
                        </li>
                    ))}
                </ul>
            </div>

            {/* Card 3: CTA */}
            <div class="relative p-8 rounded-[2rem] bg-[#3a0c10] text-white shadow-2xl flex flex-col items-center justify-center text-center overflow-hidden border border-red-900/50">
                {/* Decorative mesh glow - Softened */}
                <div class="absolute -top-[15%] -right-[15%] w-[16rem] h-[16rem] bg-brand-red opacity-20 rounded-full blur-[70px] pointer-events-none"></div>
                
                <div class="relative z-10 flex flex-col items-center justify-center h-full w-full">
                    <div class="w-16 h-16 rounded-full bg-white/5 border border-white/10 flex items-center justify-center mb-6 text-white/80">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
                    </div>
                    
                    <h4 class="text-3xl font-display font-bold mb-4 tracking-tight leading-tight text-white">¿Tu barrio no <br class="hidden sm:block" /> está en la lista?</h4>
                    <p class="text-white/70 mb-8 max-w-[280px] mx-auto text-sm leading-relaxed font-body">
                        No te preocupes. Consultanos directamente; constantemente sumamos disponibilidad en nuevas zonas a nuestro circuito.
                    </p>
                    
                    <a 
                        href="https://wa.me/1234567890" 
                        target="_blank"
                        rel="noopener noreferrer"
                        class="mt-auto w-full inline-flex items-center justify-center gap-2 px-6 py-4 text-[15px] font-semibold text-green-400 border border-green-400/50 bg-transparent rounded-xl hover:bg-green-500 hover:text-white hover:border-green-500 active:scale-[0.98] transition-all duration-300 shadow-lg shadow-green-500/10"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                        Consultá tu zona
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
