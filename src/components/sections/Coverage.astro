---
const GBA_ZONES = [
    "Ciudadela",
    "Ramos Mejía",
    "Haedo",
    "Castelar",
    "El Palomar",
];

const CABA_ZONES = [
    "Caballito",
    "Flores",
    "Floresta",
    "Monte Castro",
    "Liniers",
    "Mataderos",
    "Villa Luro",
];
---

<section id="cobertura" class="py-24 sm:py-32 bg-white relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center max-w-3xl mx-auto mb-16 px-4">
            <h2 class="text-sm font-semibold tracking-wide text-brand-red uppercase mb-3">Zonas de Cobertura</h2>
            <h3 class="text-4xl md:text-5xl font-display font-bold text-slate-900 tracking-tight lg:leading-tight mb-6">
                ¿Llegamos a tu zona?
            </h3>
            <p class="text-lg text-slate-600 font-body">
                Llevamos nuestra tecnología de diagnóstico directamente a tu domicilio. Revisá nuestras áreas de atención prioritarias.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-stretch max-w-5xl mx-auto">
            {/* Card 1: GBA Oeste */}
            <div class="p-8 rounded-[2rem] bg-white border border-slate-100 shadow-premium flex flex-col md:hover:shadow-2xl md:hover:border-slate-300 transition-all duration-300 group active:scale-[0.98] active:bg-slate-50 cursor-default">
                <div class="flex items-center gap-4 mb-8">
                    <div class="w-14 h-14 rounded-2xl bg-slate-50 flex items-center justify-center text-brand-red md:group-hover:scale-110 transition-transform duration-300">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                    </div>
                    <h4 class="text-2xl font-display font-bold text-slate-900 tracking-tight">GBA Oeste</h4>
                </div>
                
                <ul class="space-y-4 flex-grow">
                    {GBA_ZONES.map(zona => (
                        <li class="flex items-start gap-3 text-slate-600">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-brand-red/80 shrink-0 mt-0.5"><path d="M20 6 9 17l-5-5"/></svg>
                            <span class="font-medium text-[15px]">{zona}</span>
                        </li>
                    ))}
                </ul>
            </div>

            {/* Card 2: CABA */}
            <div class="p-8 rounded-[2rem] bg-white border border-slate-100 shadow-premium flex flex-col md:hover:shadow-2xl md:hover:border-slate-300 transition-all duration-300 group active:scale-[0.98] active:bg-slate-50 cursor-default">
                <div class="flex items-center gap-4 mb-8">
                    <div class="w-14 h-14 rounded-2xl bg-slate-50 flex items-center justify-center text-brand-red md:group-hover:scale-110 transition-transform duration-300">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                    </div>
                    <h4 class="text-2xl font-display font-bold text-slate-900 tracking-tight">CABA</h4>
                </div>
                
                <ul class="space-y-4 flex-grow">
                    {CABA_ZONES.map(zona => (
                        <li class="flex items-start gap-3 text-slate-600">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-brand-red/80 shrink-0 mt-0.5"><path d="M20 6 9 17l-5-5"/></svg>
                            <span class="font-medium text-[15px]">{zona}</span>
                        </li>
                    ))}
                </ul>
            </div>
        </div>
    </div>
</section>
